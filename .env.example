# Cloudflare historical log queries for scripts/query-worker-logs.mjs
# Use a narrow token intended only for log queries.
#
# Required for Workers Observability log queries:
# - CLOUDFLARE_LOG_QUERY_API_TOKEN
# - CLOUDFLARE_LOG_QUERY_ACCOUNT_ID

CLOUDFLARE_LOG_QUERY_API_TOKEN=
CLOUDFLARE_LOG_QUERY_ACCOUNT_ID=

# Cloudflare R2 JSON backups for scripts/r2-json-backup.mjs.
# Create these as R2 S3 API credentials from Cloudflare R2 > Manage R2 API tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
