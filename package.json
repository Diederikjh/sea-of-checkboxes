{
  "name": "sea-of-checkboxes",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "scripts": {
    "dev:web": "pnpm --filter sea-of-checkboxes dev",
    "dev:worker": "pnpm --filter @sea/worker dev",
    "logs:server:capture": "node scripts/capture-worker-logs.mjs",
    "logs:server:query": "node scripts/query-worker-logs.mjs",
    "logs:client:capture": "node scripts/capture-client-console.mjs",
    "r2:backup": "node scripts/r2-json-backup.mjs backup",
    "r2:restore": "node scripts/r2-json-backup.mjs restore",
    "swarm:bot": "node scripts/swarm/swarm-bot.mjs",
    "swarm:run": "node scripts/swarm/run-swarm.mjs",
    "swarm:flags": "node scripts/swarm/run-flag-matrix.mjs",
    "test": "pnpm -r test && pnpm test:scripts",
    "test:scripts": "vitest run scripts/*.test.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "^22.13.8",
    "typescript": "^5.7.3",
    "vitest": "^3.0.8"
  }
}
